# --- Data source for the BFF (app/api/v1/*) ---
# Option A: Calibre-Web-Automated backend (BFF proxies /ajax/listbooks, /cover, /download).
# Set CWA_BASE to enable; from inside Docker use host.docker.internal.
CWA_BASE=
CWA_USER=admin
CWA_PASS=admin123

# Option B: point the browser client straight at the Go backend (bypasses the BFF).
# Empty -> client uses same-origin BFF (mock, or CWA if CWA_BASE is set above).
NEXT_PUBLIC_API_BASE=
